    "react-dom": "18.3.1",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.10",
    "tsx": "4.16.2",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
