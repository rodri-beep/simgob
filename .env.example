# --- PostHog analytics ---------------------------------------------------------
# SimGob ships with its PostHog project key baked in (see lib/analytics.ts), so
# the deployed site tracks out of the box and you only need these vars to change
# the target project, region, or to switch analytics off. Copy to `.env.local`.

# Project API key (PostHog → Settings → Project → "Project API Key", starts with
# phc_). Override to point a fork at its own project, or set to "" to disable.
NEXT_PUBLIC_POSTHOG_KEY=

# Ingestion host. Leave as /ingest to use the first-party reverse proxy defined
# in next.config.mjs (recommended; dodges ad-blockers). For a fully static deploy
# without rewrites, set it to https://eu.i.posthog.com instead.
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# PostHog app/region host. EU cloud by default; use https://us.posthog.com for US.
NEXT_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com
